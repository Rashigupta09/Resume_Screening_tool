# Copy to .env and fill in. The tool reads these via python-dotenv.

# AWS region for Bedrock. Locked to us-east-1 for this POC.
AWS_REGION=us-east-1

# Auth: a Bedrock API key (bearer token), NOT IAM/SigV4 credentials.
# Long-term Bedrock API keys start with "ABSK". boto3/botocore reads this env var
# automatically for the bedrock-runtime client.
AWS_BEARER_TOKEN_BEDROCK=ABSK...

# Bedrock model ID for Claude Sonnet 4.6 — confirmed working in us-east-1.
# The bare id "anthropic.claude-sonnet-4-6" is rejected for on-demand throughput;
# it needs this US cross-region inference profile.
MODEL_ID=us.anthropic.claude-sonnet-4-6

# Optional: faster/cheaper model for Call 2 (evaluation) ONLY. Defaults to MODEL_ID.
# Set this to trade some reasoning quality for speed if scoring feels slow.
# EVAL_MODEL_ID=us.anthropic.claude-haiku-4-5

# Folder the UI/CLI reads sample JD + CVs from.
INPUT_DIR=data
